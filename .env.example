# Optional runtime home. Defaults to ~/.flat_searcher
FLAT_SEARCHER_HOME=

# Optional database path. Defaults to <FLAT_SEARCHER_HOME>/flat_searcher.sqlite3
FLAT_SEARCHER_DB_PATH=

# Gemini AI integration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Future geocoding / OSM settings
OVERPASS_ENDPOINT=https://overpass-api.de/api/interpreter
